{
  "name": "virgil",
  "displayName": "Virgil",
  "description": "Self-hosted security audit, in your editor. Run scans, surface findings as inline diagnostics, and triage from the command palette — powered by the bundled Virgil CLI (no Python required).",
  "version": "0.2.0",
  "publisher": "ayaanmaliksgithub",
  "license": "Apache-2.0",
  "homepage": "https://virgilhq.app",
  "repository": {
    "type": "git",
    "url": "https://github.com/ayaanmaliksgithub/virgil.git",
    "directory": "apps/vscode"
  },
  "bugs": {
    "url": "https://github.com/ayaanmaliksgithub/virgil/issues"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Linters",
    "Other"
  ],
  "keywords": [
    "security",
    "audit",
    "sast",
    "semgrep",
    "trivy",
    "gitleaks",
    "virgil"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "virgil.scan",
        "title": "Virgil: Scan workspace"
      },
      {
        "command": "virgil.setAudit",
        "title": "Virgil: Track an existing audit ID for this workspace"
      },
      {
        "command": "virgil.clearAudit",
        "title": "Virgil: Clear the tracked audit"
      },
      {
        "command": "virgil.refresh",
        "title": "Virgil: Refresh diagnostics"
      },
      {
        "command": "virgil.openInBrowser",
        "title": "Virgil: Open the current audit in your browser"
      }
    ],
    "configuration": {
      "title": "Virgil",
      "properties": {
        "virgil.cliPath": {
          "type": "string",
          "default": "",
          "description": "Optional. Absolute path to a `virgil` binary to use instead of the one the extension downloads. Useful when developing the CLI locally — point this at `apps/cli/dist/virgil`."
        },
        "virgil.minSeverity": {
          "type": "string",
          "enum": ["Critical", "High", "Medium", "Low", "Informational"],
          "default": "Low",
          "description": "Lowest severity to surface as a diagnostic. Findings below this floor are silently dropped."
        },
        "virgil.includeSuppressed": {
          "type": "boolean",
          "default": false,
          "description": "Show findings that are suppressed on the server. Off by default to match the web UI."
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "vscode:prepublish": "npm run compile"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.85.0",
    "typescript": "^5.4.0"
  }
}
