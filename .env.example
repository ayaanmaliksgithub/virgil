## Core
DATABASE_URL=postgresql+psycopg://audit:audit@postgres:5432/audit
REDIS_URL=redis://redis:6379/0

## Storage (MinIO locally; same client code in prod against real S3)
S3_ENDPOINT=http://minio:9000
S3_REGION=us-east-1
S3_BUCKET=virgil
S3_ACCESS_KEY=minio
S3_SECRET_KEY=miniominio

## Limits
JOB_TIMEOUT_SECONDS=900
SCAN_TIMEOUT_SECONDS=600
MAX_REPO_BYTES=524288000
MAX_UPLOAD_BYTES=524288000

## Sandbox
CONTAINER_RUNTIME=docker
SCANNER_IMAGE=virgil/scanner:latest
SANDBOX_CPUS=2
SANDBOX_MEMORY=4g
SANDBOX_PIDS=512

## Scanner config
SEMGREP_RULESETS=p/owasp-top-ten,p/security-audit,p/secrets
# Phase 4 #6 — Optional host-side directory of org-custom Semgrep rule files
# (*.yaml). Mounted read-only at /custom-rules in the sandbox and added as an
# extra `--config` arg. Sandbox stays --network=none, so PRE-FETCH any remote
# rule pack into this directory; runtime URL fetches will fail.
SEMGREP_CUSTOM_RULES_DIR=
ENABLE_CODEQL=false
CODEQL_LANGUAGES=python,javascript-typescript,ruby,go

## LLM (pluggable)
LLM_PROVIDER=anthropic
LLM_MODEL=claude-opus-4-7
LLM_MAX_TOKENS_PER_AUDIT=200000
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

## API
API_CORS_ORIGINS=["http://localhost:3000"]

## Outbound webhook (Phase 5 — minimal). When both are set the worker POSTs
## an `audit.completed` payload to WEBHOOK_URL after each successful audit.
## Body is HMAC-sha256 signed with WEBHOOK_SECRET; receivers verify via
## the `X-Audit-Signature: sha256=<hex>` header. Per-org endpoints + retry
## queue land with Phase 3 orgs/teams.
WEBHOOK_URL=
WEBHOOK_SECRET=

## Secret encryption for private repository credentials.
## Generate with:
## python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
SECRET_ENCRYPTION_KEY=
